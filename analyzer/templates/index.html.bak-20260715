  // Recent bi (笔)
  if (d.recent_bi && d.recent_bi.length > 0) {
    detail += '<div style="margin:8px 0"><strong>📏 近期笔</strong></div>';
    d.recent_bi.slice(-5).forEach(b => {
      const color = b.direction==='up'?'var(--green)':'var(--red)';
      const arrow = b.direction==='up'?'↑':'↓';
      detail += `<span style="display:inline-block;padding:3px 8px;margin:2px;background:rgba(0,0,0,0.2);border-radius:3px;font-size:12px;color:${color}">
        ${arrow} ${b.start_date?.slice(5)}→${b.end_date?.slice(5)} ${b.start_price?.toFixed(0)}→${b.end_price?.toFixed(0)}</span>`;
    });
  }
  
  // Zhongshu
  if (d.zhongshu && d.zhongshu.length > 0) {
    detail += '<div style="margin:8px 0"><strong>🔲 中枢</strong></div>';
    d.zhongshu.forEach(z => {
      detail += `<div style="padding:6px;margin:4px 0;background:rgba(88,166,255,0.08);border-radius:4px;font-size:13px">
        ZG=${z.zg?.toFixed(0)} ZD=${z.zd?.toFixed(0)} | GG=${z.high?.toFixed(0)} DD=${z.low?.toFixed(0)} | ${z.bi_count}笔</div>`;
    });
  }
  
  document.getElementById('chanlunDetail').innerHTML = detail || '<div style="color:var(--text2)">暂无信号</div>';
}

async function loadIndicators(idx='sh') {
  document.getElementById('btnIndSH').style.background = idx==='sh'?'var(--accent)':'var(--border)';
  document.getElementById('btnIndCYB').style.background = idx==='cyb'?'var(--accent)':'var(--border)';
  
  const d = await fetchAPI('/api/indicators?index=' + (idx==='cyb'?'sz':'sh'));
  if (d.error) { document.getElementById('indicatorsPanel').innerHTML = '❌ '+d.error; return; }
  
  const indRows = [
    {name:'RSI', val:d.rsi?.value, unit:'', zone:d.rsi?.zone, div:d.rsi?.divergence},
    {name:'布林带', val:'', unit:'', zone:d.boll?.position, div:d.boll?.squeeze},
    {name:'均线', val:'', unit:'', zone:d.ma?.arrangement+' | '+d.ma?.cross, div:d.ma?.life_line},
    {name:'KDJ', val:`K:${d.kdj?.k} D:${d.kdj?.d} J:${d.kdj?.j}`, unit:'', zone:d.kdj?.zone, div:(d.kdj?.cross||'')+(d.kdj?.j_signal?' | '+d.kdj?.j_signal:'')},
    {name:'量价', val:d.volume?.vol_vs_avg20+'%vs20日均', unit:'', zone:'', div:d.volume?.divergence||'正常'},
    {name:'多周期', val:'', unit:'', zone:d.multi_timeframe?.resonance, div:`日${d.multi_timeframe?.daily?.trend} 周${d.multi_timeframe?.weekly?.trend} 月${d.multi_timeframe?.monthly?.trend}`},
  ];
  
  let html = '<table><thead><tr><th>指标</th><th>值</th><th>状态</th><th>信号</th></tr></thead><tbody>';
  indRows.forEach(r => {
    const color = (r.zone||'').includes('多')||r.zone.includes('金叉')?'var(--green)':(r.zone.includes('空')||r.zone.includes('超买')||r.zone.includes('死叉')?'var(--red)':'var(--text2)');
    html += `<tr><td><strong>${r.name}</strong></td><td style="font-size:12px">${r.val}</td><td style="color:${color};font-size:12px">${r.zone}</td><td style="font-size:11px;color:var(--yellow)">${r.div||''}</td></tr>`;
  });
  
  // 缺口
  if (d.gaps && d.gaps.length > 0) {
    html += '<tr><td colspan="4" style="padding-top:8px"><strong>缺口：</strong>';
    d.gaps.forEach(g => {
      const icon = g.type==='向上缺口'?'🟢':'🔴';
      const status = g.filled?'已回补':'⚠️未回补';
      html += `<span style="margin:2px;display:inline-block;padding:2px 6px;background:rgba(0,0,0,0.2);border-radius:3px;font-size:11px">${icon}${g.date} ${g.type} ${g.bottom}-${g.top} ${status}</span>`;
    });
    html += '</td></tr>';
  }
  
  // 均线值
  if (d.ma?.values) {
    html += '<tr><td colspan="4" style="font-size:11px;color:var(--text2)">';
    const mv = d.ma.values;
    html += `MA5:${mv.ma5||'-'} MA10:${mv.ma10||'-'} MA20:${mv.ma20||'-'} MA60:${mv.ma60||'-'} MA120:${mv.ma120||'-'}`;
    html += '</td></tr>';
  }
  
  html += '</tbody></table>';
  document.getElementById('indicatorsPanel').innerHTML = html;
  
  // 综合评分面板
  const cs = d.composite_score;
  if (cs) {
    const scoreColor = cs.score>1.5?'var(--green)':cs.score<-1.5?'var(--red)':'var(--yellow)';
    const barWidth = Math.min(100, Math.abs(cs.score)*15);
    const barDir = cs.score >= 0;
    
    let scoreHtml = `
    <div style="text-align:center;margin-bottom:16px">
      <div style="font-size:42px;font-weight:800;color:${scoreColor}">${cs.score>0?'+':''}${cs.score}</div>
      <div style="font-size:16px;color:${scoreColor};margin-top:4px">${cs.verdict}</div>
      <div style="margin-top:8px;height:8px;background:var(--border);border-radius:4px;overflow:hidden">
        <div style="height:100%;width:${barWidth}%;background:${scoreColor};border-radius:4px;float:${barDir?'left':'right'}"></div>
      </div>
      <div style="display:flex;justify-content:space-between;font-size:11px;color:var(--text2);margin-top:4px">
        <span>🐻 看空</span><span>😐 中性</span><span>看多 🐂</span>
      </div>
    </div>
    <div style="margin-top:12px;font-size:12px">
      <div style="display:flex;gap:8px;margin-bottom:8px">
        <span style="padding:4px 8px;background:rgba(63,185,80,0.15);border-radius:4px;color:var(--green)">多方 ${cs.bull}票</span>
        <span style="padding:4px 8px;background:rgba(248,81,73,0.15);border-radius:4px;color:var(--red)">空方 ${cs.bear}票</span>
      </div>`;
    
    cs.votes.forEach(v => {
      const icon = v[1]>0?'🟢':v[1]<0?'🔴':'⚪';
      const color = v[1]>0?'var(--green)':v[1]<0?'var(--red)':'var(--text2)';
      scoreHtml += `<div style="padding:4px 0;border-bottom:1px solid rgba(48,54,61,0.3)">${icon} <span style="color:${color}">${v[0]}</span> <span style="float:right;color:${color}">${v[1]>0?'+':''}${v[1].toFixed(1)}</span></div>`;
    });
    
    scoreHtml += '</div>';
    document.getElementById('scorePanel').innerHTML = scoreHtml;
  }
}

async function loadStockAnalysis() {
  const input = document.getElementById('stockSearchInput').value.trim();
  if (!input) { d...[truncated]

async function loadStockAnalysis() {
  const input = document.getElementById('stockSearchInput').value.trim();
  if (!input) { document.getElementById('stockResult').innerHTML = '⚠️ 请输入股票名称或代码'; return; }
  
  const btn = document.getElementById('btnStockSearch');
  btn.disabled = true; btn.textContent = '分析中...';
  document.getElementById('stockResult').innerHTML = '<div style="text-align:center;padding:20px;color:var(--text2)">⏳ 正在获取数据并计算技术指标...</div>';
  
  // 判断是代码还是名称
  const isCode = /^\d{6}$/.test(input);
  const url = '/api/stock-analysis?' + (isCode ? 'code=' + input : 'name=' + encodeURIComponent(input));
  
  const d = await fetchAPI(url);
  btn.disabled = false; btn.textContent = '分析';
  
  if (d.error) { document.getElementById('stockResult').innerHTML = '❌ ' + d.error; return; }
  
  const cs = d.composite_score;
  const scoreColor = cs.score>1.5?'var(--green)':cs.score<-1.5?'var(--red)':'var(--yellow)';
  const poolBadge = d.in_wu2198_pool ? '<span style="padding:3px 8px;background:rgba(63,185,80,0.2);border-radius:4px;color:var(--green);font-size:12px">✅ wu2198池内</span>' : '';
  
  let html = `
  <div style="display:flex;gap:16px;flex-wrap:wrap;margin-bottom:16px">
    <div style="flex:2;min-width:200px">
      <div style="font-size:24px;font-weight:700">${d.name} (${d.code}) ${poolBadge}</div>
      <div style="font-size:14px;color:var(--text2);margin-top:4px">${d.current_date} 收盘 ${d.current_price}</div>
      <div style="margin-top:6px">
        <span style="padding:3px 8px;border-radius:4px;font-size:12px;${d.pct_today>0?'background:rgba(63,185,80,0.15);color:var(--green)':'background:rgba(248,81,73,0.15);color:var(--red)'}">
          今日${d.pct_today>0?'↑':'↓'}${d.pct_today}%</span>
        <span style="padding:3px 8px;border-radius:4px;font-size:12px;${d.pct_5d>0?'background:rgba(63,185,80,0.15);color:var(--green)':'background:rgba(248,81,73,0.15);color:var(--red)'}">
          5日${d.pct_5d>0?'↑':'↓'}${d.pct_5d}%</span>
        ${d.pct_20d!=null?`<span style="padding:3px 8px;border-radius:4px;font-size:12px;${d.pct_20d>0?'background:rgba(63,185,80,0.15);color:var(--green)':'background:rgba(248,81,73,0.15);color:var(--red)'}">
          20日${d.pct_20d>0?'↑':'↓'}${d.pct_20d}%</span>`:''}
      </div>
      ${d.pool_info?`<div style="margin-top:6px;font-size:12px;color:var(--text2)">板块:${d.pool_info.sector||'-'} | 得分:${d.pool_info.score||0} | 类别:${d.pool_info.bucket||'-'}</div>`:''}
    </div>
    <div style="flex:1;min-width:150px;text-align:center;padding:12px;background:rgba(0,0,0,0.2);border-radius:8px">
      <div style="font-size:11px;color:var(--text2)">综合评分</div>
      <div style="font-size:36px;font-weight:800;color:${scoreColor}">${cs.score>0?'+':''}${cs.score}</div>
      <div style="font-size:14px;color:${scoreColor}">${cs.verdict}</div>
      <div style="margin-top:4px;font-size:11px;color:var(--text2)">多${cs.bull}票 / 空${cs.bear}票</div>
    </div>
  </div>`;
  
  // 指标表格
  html += '<table style="width:100%"><thead><tr><th>指标</th><th>值</th><th>状态</th><th>信号</th></tr></thead><tbody>';
  const rows = [
    {n:'RSI',v:d.rsi?.value,z:d.rsi?.zone,s:d.rsi?.divergence},
    {n:'布林',v:'',z:d.boll?.position,s:d.boll?.squeeze},
    {n:'均线',v:'',z:d.ma?.arrangement+'|'+d.ma?.cross,s:d.ma?.life_line},
    {n:'KDJ',v:`K:${d.kdj?.k} D:${d.kdj?.d} J:${d.kdj?.j}`,z:d.kdj?.zone,s:d.kdj?.cross+(d.kdj?.j_signal?' '+d.kdj?.j_signal:'')},
    {n:'量价',v:d.volume?.vol_vs_avg20+'%',z:'',s:d.volume?.divergence||'正常'},
    {n:'多周期',v:'',z:d.multi_timeframe?.resonance,s:`日${d.multi_timeframe?.daily?.trend}周${d.multi_timeframe?.weekly?.trend}月${d.multi_timeframe?.monthly?.trend}`},
  ];
  rows.forEach(r => {
    const c = (r.z||'').match(/多|金叉|偏多/)?'var(--green)':(r.z.match(/空|超买|死叉/)?'var(--red)':'var(--text2)');
    html += `<tr><td><strong>${r.n}</strong></td><td style="font-size:12px">${r.v||''}</td><td style="color:${c};font-size:12px">${r.z||''}</td><td style="font-size:11px;color:var(--yellow)">${r.s||''}</td></tr>`;
  });
  html += '</tbody></table>';
  
  // 缠论信号
  const sigs = d.chanlun_signals||[];
  if (sigs.length) {
    html += '<div style="margin-top:12px"><strong>🎯 缠论买卖点</strong></div>';
    sigs.forEach(s => {
      const ic = s.kind.includes('buy')?'🟢':'🔴';
      html += `<div style="padding:4px;margin:2px 0;background:rgba(0,0,0,0.2);border-radius:4px;font-size:12px">${ic} ${s.kind} ${s.price?.toFixed(0)}→${s.description}</div>`;
    });
  }
  
  // 形态
  const pts = d.chanlun_patterns||[];
  if (pts.length) {
    html += '<div style="margin-top:8px"><strong>📐 形态</strong></div>';
    pts.forEach(p => {
      html += `<div style="font-size:12px">${p.bearish?'⚠️':'✅'} ${p.name} → 目标${p.target}</div>`;
    });
  }
  
  // 缺口
  if (d.gaps?.length) {
    html += '<div style="margin-top:8px;font-size:12px"><strong>缺口：</strong>';
    d.gaps.forEach(g => html += `<span style="margin:2px;padding:2px 6px;background:rgba(0,0,0,0.2);border-radius:3px">${g.type==='向上缺口'?'🟢':'🔴'}${g.date} ${g.bottom}-${g.top} ${g.filled?'已回补':'⚠️未回补'}</span>`);
    html += '</div>';
  }
  
  // 投票明细 - 加入wu2198视角
  const wu = d.wu_eval;
  if (wu) {
    html += '<div style="margin-top:16px;padding:12px;background:rgba(88,166,255,0.1);border:1px solid rgba(88,166,255,0.3);border-radius:8px">';
    html += '<div style="font-size:15px;font-weight:700;color:var(--accent);margin-bottom:8px">🧭 wu2198视角评价</div>';
    html += `<div style="font-size:13px;margin-bottom:6px">${wu.pool_status} | ${wu.direction_match}</div>`;
    html += `<div style="font-size:18px;font-weight:700;margin-bottom:4px">wu2198评分: ${wu.wu_final_score>0?'+':''}${wu.wu_final_score}</div>`;
    html += `<div style="font-size:14px;margin-bottom:6px">${wu.suggestion}</div>`;
    html += `<div style="font-size:13px;color:var(--text2)">建议仓位: ${wu.position}</div>`;
    html += `<div style="margin-top:8px;padding:8px;background:rgba(0,0,0,0.2);border-radius:4px;font-size:12px;color:var(--text)">${wu.one_liner}</div>`;
    html += '</div>';
  }
  
  document.getElementById('stockResult').innerHTML = html;
}

// Enter键触发搜索
document.getElementById('stockSearchInput')?.addEventListener('keydown', e => {
  if (e.key === 'Enter') loadStockAnalysis();
});

// === 每日策略 ===
async function loadDailyStrategy() {
  const d = await fetchAPI('/api/daily-strategy');
  if (d.error) { document.getElementById('dailyStrategy').innerHTML = '❌ '+d.error; return; }
  
  const s = d.strategy_summary || {};
  const sh = d.sh_view || {};
  const cyb = d.cyb_view || {};
  
  const scoreColor = sh.blended_score>=1?'var(--green)':sh.blended_score<=-1.5?'var(--red)':'var(--yellow)';
  
  let html = `
  <div style="text-align:center;margin-bottom:12px">
    <div style="font-size:12px;color:var(--text2)">${d.date} 策略</div>
    <div style="font-size:18px;font-weight:700;margin-top:4px">${d.headline}</div>
  </div>
  <div style="text-align:center;margin-bottom:12px;padding:12px;background:rgba(0,0,0,0.2);border-radius:8px">
    <div style="font-size:11px;color:var(--text2)">融合评分(wu2198×技术)</div>
    <div style="font-size:32px;font-weight:800;color:${scoreColor}">${sh.blended_score>0?'+':''}${sh.blended_score}</div>
    <div style="font-size:14px;color:${scoreColor}">${sh.verdict}</div>
  </div>`;
  
  const items = [
    ['📍 大盘方向', s['大盘方向']],
    ['💰 仓位建议', s['仓位建议']],
    ['⏱️ 操作节奏', s['操作节奏']],
    ['🎯 重点方向', s['重点方向']],
    ['🔮 关注个股', s['关注个股']],
    ['⚠️ 风险提示', s['风险提示']],
  ];
  items.forEach(([k,v]) => {
    html += `<div style="padding:6px 0;border-bottom:1px solid rgba(48,54,61,0.2)"><span style="color:var(--text2)">${k}</span><div style="font-size:13px;margin-top:2px">${v}</div></div>`;
  });
  
  // 关键点位
  if (d.key_levels) {
    html += '<div style="margin-top:8px;font-size:11px;color:var(--text2)">';
    const sh_l = d.key_levels['上证']||{};
    const cyb_l = d.key_levels['创业板']||{};
    if (sh_l.resistance) html += `上证: 反压${sh_l.resistance} 目标${sh_l.break_4070_target||'?'} | `;
    if (cyb_l.short_term_pivot) html += `创业板: 短线${cyb_l.short_term_pivot} 中线${cyb_l.medium_term_pivot}`;
    html += '</div>';
  }
  
  // wu2198锚点
  if (d.wu2198_anchors && d.wu2198_anchors.length) {
    html += '<div style="margin-top:8px"><details><summary style="cursor:pointer;color:var(--accent);font-size:12px">📌 wu2198核心判断锚点</summary>';
    d.wu2198_anchors.forEach(a => { html += `<div style="padding:2px 0;font-size:11px;color:var(--text2)">• ${a}</div>`; });
    html += '</details></div>';
  }
  
  document.getElementById('dailyStrategy').innerHTML = html;
}

loadDailyStrategy();

